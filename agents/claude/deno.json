{
	"$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
	"compilerOptions": {
		"strict": true,
		"lib": ["deno.window"]
	},
	"fmt": {
		"useTabs": false,
		"lineWidth": 100,
		"indentWidth": 2,
		"singleQuote": true
	},
	"lint": {
		"rules": {
			"tags": ["recommended"]
		}
	},
	"imports": {
		"@std/fs": "jsr:@std/fs@^1.0.22",
		"@std/path": "jsr:@std/path@^1.1.4"
	},
	"tasks": {
		"statusline:check": "deno check statusline.ts"
	}
}
