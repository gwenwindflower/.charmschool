{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"DISABLE_AUTO_UPDATER": "1"
	},
	"permissions": {
		"allow": [
			"Bash(* --help *)",
			"Bash(* --version)",
			"Bash(bat *)",
			"Bash(cat *)",
			"Bash(echo *)",
			"Bash(fd *)",
			"Bash(find *)",
			"Bash(git branch *)",
			"Bash(git diff *)",
			"Bash(git log *)",
			"Bash(git show *)",
			"Bash(git stash list)",
			"Bash(git status *)",
			"Bash(go build *)",
			"Bash(go run main.go)",
			"Bash(go test *)",
			"Bash(go tool pprof *)",
			"Bash(go vet *)",
			"Bash(gofmt *)",
			"Bash(gopls *)",
			"Bash(grep *)",
			"Bash(ls *)",
			"Bash(lsd *)",
			"Bash(make *)",
			"Bash(notesmd-cli search *)",
			"Bash(notesmd-cli search-content *)",
			"Bash(npm run build)",
			"Bash(npm run dev)",
			"Bash(npm run lint)",
			"Bash(npm run test *)",
			"Bash(npx tsc *)",
			"Bash(pnpm run build)",
			"Bash(pnpm run dev)",
			"Bash(pnpm run lint)",
			"Bash(pnpm run test *)",
			"Bash(printf *)",
			"Bash(pwd)",
			"Bash(rg *)",
			"Bash(skillutil *)",
			"Bash(task *)",
			"Bash(tree *)",
			"Bash(uname *)",
			"Bash(wc *)",
			"Bash(which *)",
			"Bash(yuzudraw-cli *)",
			"Skill(chezmoi)",
			"Skill(develop-agent-skills)",
			"Skill(fish-functions)",
			"Skill(gh-cli-use)",
			"Skill(gitignore)",
			"Skill(neovim-config)",
			"Skill(neovim-plugin-development)",
			"Skill(rotz-dotfiles)",
			"WebFetch(domain:agentskills.io)",
			"WebFetch(domain:chezmoi.io)",
			"WebFetch(domain:claude.com)",
			"WebFetch(domain:codecompanion.olimorris.dev)",
			"WebFetch(domain:context7.com)",
			"WebFetch(domain:docs.brew.sh)",
			"WebFetch(domain:docs.deno.com)",
			"WebFetch(domain:fishshell.com)",
			"WebFetch(domain:git-cliff.org)",
			"WebFetch(domain:jdx.dev)",
			"WebFetch(domain:jsr.io)",
			"WebFetch(domain:lazyvim.org)",
			"WebFetch(domain:neovim.io)",
			"WebFetch(domain:opencode.ai)",
			"WebFetch(domain:pkg.go.dev)",
			"WebFetch(domain:registry.npmjs.org)",
			"WebFetch(domain:sum.golang.org)",
			"WebFetch(domain:sw.kovidgoyal.net)",
			"WebFetch(domain:worktrunk.dev)"
		],
		"deny": [
			"Read(.env)",
			"Read(.env.*)",
			"Read(*.env)",
			"Read(~/.ssh/**)",
			"Read(~/.aws/**)",
			"Read(~/.gnupg/**)",
			"Read(~/.config/gcloud/**)",
			"Read(**/secrets/**)",
			"Read(**/credentials/**)",
			"Read(*.pem)",
			"Read(*.key)",
			"Read(*.p12)",
			"Read(*.pfx)",
			"Read(id_rsa)",
			"Read(id_ed25519)",
			"Edit(.env)",
			"Edit(.env.*)",
			"Edit(*.env)",
			"Edit(~/.ssh/**)",
			"Edit(~/.aws/**)",
			"Edit(~/.gnupg/**)",
			"Edit(~/.config/gcloud/**)",
			"Edit(**/secrets/**)",
			"Edit(**/credentials/**)",
			"Edit(*.pem)",
			"Edit(*.key)",
			"Edit(*.p12)",
			"Edit(*.pfx)",
			"Edit(id_rsa)",
			"Edit(id_ed25520)",
			"Bash(rm -rf *)",
			"Bash(rm -rf /*)",
			"Bash(sudo rm *)",
			"Bash(chmod -R 777 *)",
			"Bash(dd *)",
			"Bash(mkfs *)",
			"Bash(git push --force *)",
			"Bash(git push -f *)",
			"Bash(kubectl delete *)",
			"Bash(kubectl apply * --namespace=prod*)",
			"Bash(terraform destroy *)",
			"Bash(op *)",
			"Bash(chezmoi *)"
		]
	},
	"hooks": {
		"SubagentStart": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/inject-commit-reminder.sh"
					}
				]
			}
		],
		"TaskCompleted": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": ".claude/hooks/require-teammate-commit.sh"
					}
				]
			}
		]
	},
	"statusLine": {
		"type": "command",
		"command": "winline",
		"padding": 0
	},
	"enabledPlugins": {
		"gopls-lsp@claude-plugins-official": true,
		"lua-lsp@claude-plugins-official": true,
		"pyright-lsp@claude-plugins-official": true,
		"rust-analyzer-lsp@claude-plugins-official": true,
		"typescript-lsp@claude-plugins-official": true,
		"worktrunk@worktrunk": true
	},
	"sandbox": {
		"enabled": true,
		"autoAllowBashIfSandboxed": false,
		"allowUnsandboxedCommands": false,
		"network": {
			"allowedDomains": [
				"telemetry.astro.build",
				"registry.npmjs.org",
				"proxy.golang.org",
				"registry.npmjs.org",
				"pkg.go.dev",
				"sum.golang.org",
				"storage.googleapis.com",
				"context7.com",
				"jsr.io"
			],
			"allowLocalBinding": true
		},
		"filesystem": {
			"allowWrite": [
				"~/.local/share/graveyard/**",
				"~/.local/share/pnpm/**",
				"~/.cache/pnpm/**",
				"~/Documents/YuzuDraw",
				"~/Library/Caches/go-build"
			]
		}
	},
	"spinnerTipsEnabled": false,
	"spinnerVerbs": {
		"mode": "replace",
		"verbs": [
			"Being a pretty pony",
			"Crocheting a cat sweater",
			"Kekeking",
			"Romanticizing everything",
			"Crying to Chappell Roan",
			"Painting my nails",
			"Doing pilates",
			"Ordering an iced oat milk latte",
			"Lipglossing",
			"Cuddling my cat",
			"Shopping for cute jeans",
			"Journaling with niche Japanese stationery",
			"Passenger princessing",
			"Being chaotic",
			"Fangirling",
			"Dancing with the dolls",
			"Buying colorful candles",
			"Fixing my hair tie",
			"Stretching my hips",
			"Doing witchcraft with the coven",
			"Hydrating",
			"Catastrophizing",
			"Good girling",
			"Collecting little trinkets",
			"Thirsting over fictional men",
			"Having a mental breakdown aesthetically",
			"Girlmaxxing",
			"Dating your boyfriend",
			"Dancing on my own",
			"Getting a little treat",
			"Curating Spotify playlists",
			"K-Pop demon hunting",
			"Braiding friendship bracelets",
			"Rephrasing in therapy language",
			"Junk journaling",
			"Manifesting",
			"Horse girling",
			"Being hot",
			"Shopping with the girlypops"
		]
	},
	"syntaxHighlightingDisabled": false,
	"voiceEnabled": true
}
