{
	"$schema": "https://opencode.ai/config.json",

	"model": "github-copilot/claude-sonnet-4.6",
	"small_model": "github-copilot/gpt-5.4-mini",

	"enabled_providers": ["github-copilot"],

	// OPENCODE_CONFIG_DIR is set to ~/.agents in fish config, which gives us
	// access to ~/.agents/{rules,skills,agents,prompts}
	"instructions": [
		"AGENTS.md",
		"~/.agents/rules/*.md",
		".claude/docs/**/*.md",
		".claude/rules/**/*.md"
	],
	"snapshot": true,
	// Updated via Homebrew
	"autoupdate": false
}
